{
  "manifest_version": 3,
  "name": "Clean LinkedIn",
  "version": "1.0.0",
  "description": "Strip LinkedIn down to signal. Remove all noise.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "./icons/icon48.png",
    "default_title": "Clean LinkedIn"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ]
}
